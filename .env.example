# Copy to .env.local and fill in. .env.local is gitignored — never commit real secrets.
#
# CB Hub is env-gated. With NONE of these set, the app runs the dev stub + in-memory
# store (fully clickable, zero credentials). Setting the Neon vars below switches both
# auth and data to Neon Auth (Better Auth) + Drizzle/Neon Postgres. See AGENTS.md
# ("How to wire the database").

# --- Neon Postgres (Drizzle) ---------------------------------------------------
# Pooled connection — used by the app at runtime. Neon dashboard → Connect → Pooled.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct / unpooled connection — used by migrations and one-shot scripts (db:seed).
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Neon Auth (Better Auth) ---------------------------------------------------
# Auth base URL from Neon Auth, enabled on your default branch.
NEON_AUTH_BASE_URL="https://EP-XXXX.neonauth.REGION.aws.neon.tech/neondb/auth"
# Cookie signing secret, >= 32 chars. Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=""

# --- Bootstrap admin (optional) ------------------------------------------------
# The Neon Auth user id (a UUID minted on first sign-in) to seed as master_admin.
# IMPORTANT: this must be the real auth-user UUID, NOT a name or email.
# Note: getCurrentUser() already auto-provisions the owner's Google account as
# master_admin by email on first sign-in, so this var is usually unnecessary.
# Leave blank to skip the seeded bootstrap profile.
BOOTSTRAP_ADMIN_USER_ID=""
