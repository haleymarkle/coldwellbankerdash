# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# claude code build artifacts
.cb-build-workflow.mjs

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template (no secrets) is committed for onboarding
!.env.example

# other package managers — this project standardizes on npm (package-lock.json)
pnpm-lock.yaml
pnpm-workspace.yaml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
